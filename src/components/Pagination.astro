---
interface Props {
  currentPage: number;
  lastPage: number;
  basePath: string;
}

const { currentPage, lastPage, basePath } = Astro.props;

const MAX_PAGES = 7;

const getPages = (): Array<number | 'dots'> => {
  if (lastPage <= MAX_PAGES) {
    return Array.from({ length: lastPage }, (_, i) => i + 1);
  }

  const pages: Array<number | 'dots'> = [1];
  const start = Math.max(2, currentPage - 1);
  const end = Math.min(lastPage - 1, currentPage + 1);

  if (start > 2) pages.push('dots');

  for (let i = start; i <= end; i++) {
    pages.push(i);
  }

  if (end < lastPage - 1) pages.push('dots');

  pages.push(lastPage);
  return pages;
};

const getHref = (page: number): string => {
  if (page === 1) {
    return basePath === '/page' ? '/' : `${basePath}/`;
  }
  return `${basePath}/${page}/`;
};

const pages = getPages();
---

<nav>
  <ul>
    {
      pages.map((page) =>
        page === 'dots' ? (
          <li>
            <span>…</span>
          </li>
        ) : (
          <li>
            {page === currentPage ? (
              <span aria-current="page">{page}</span>
            ) : (
              <a href={getHref(page)}>{page}</a>
            )}
          </li>
        )
      )
    }
  </ul>
</nav>

<style lang="scss">
  ul {
    display: flex;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  a,
  span {
    padding: 0.2rem 0.6rem;
    font-size: 90%;
    text-decoration: none;
    border-radius: 9999px;
  }

  a {
    color: inherit;
    border: 1px solid #777;
    transition: background-color 0.2s ease;

    &:hover {
      background-color: rgb(0 0 0 / 10%);
    }
  }

  span[aria-current='page'] {
    color: #fff;
    background-color: #111;
  }
</style>
