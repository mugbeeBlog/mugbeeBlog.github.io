---
const { pathname } = Astro.url;

const navItems = [
  { href: '/', label: '最新記事' },
  { href: '/taxonomy/', label: 'カテゴリ・タグの一覧' },
  { href: '/info/', label: '運営情報' },
];

const isActive = (href: string) =>
  href === '/' ? pathname === href : pathname.startsWith(href);
---

<nav>
  <ul>
    {
      navItems.map(({ href, label }) => {
        const active = isActive(href);
        return (
          <li>
            <a
              href={href}
              class:list={{ active }}
              aria-current={active ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>

<style lang="scss">
  ul {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  a {
    position: relative;
    display: inline-flex;
    padding: 0.5rem 1rem;
    overflow: hidden;
    font-size: 110%;
    color: inherit;
    text-decoration: none;
    border-radius: 12px;

    &::before {
      position: absolute;
      inset: 0;
      z-index: -1;
      content: '';
      background-color: rgb(0 0 0 / 40%);
      transform: scaleY(0);
      transform-origin: bottom;
      transition: transform 0.3s ease;
    }

    &:hover::before {
      transform: scaleY(1);
    }
  }

  a.active,
  a[aria-current='page'] {
    font-weight: 700;
    color: #fff;
    background-color: #111;
  }
</style>
