---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Taxonomy from './Taxonomy.astro';
import { formatJPDate, toISODateTime } from '../utils/date';

interface Props {
  blogs: CollectionEntry<'blogs'>[];
}

const { blogs } = Astro.props;

const DEFAULT_THUMBNAIL_PATH = '/images/no-images.png';
const DESCRIPTION_MAX_LENGTH = 80;

function truncateText(text: string, maxLength: number): string {
  return text.length <= maxLength
    ? text
    : `${text.slice(0, maxLength).trim()}…`;
}
---

{
  blogs.length > 0 ? (
    <ul class="stack">
      {blogs.map((post) => {
        const postUrl = `/${post.data.slug}/`;
        const postDate = post.data.publishedAt;
        const thumbnail = post.data.thumbnail;
        const thumbnailUrl = thumbnail?.url ?? DEFAULT_THUMBNAIL_PATH;
        const thumbnailAlt = thumbnail?.url
          ? `${post.data.title}のサムネイル画像`
          : 'デフォルト画像';

        return (
          <li>
            <article>
              <a
                href={postUrl}
                aria-hidden="true"
                tabindex="-1"
                class="thumbnail"
              >
                <Image
                  src={thumbnailUrl}
                  alt={thumbnailAlt}
                  width={400}
                  height={400}
                />
              </a>

              <div class="meta-data stack">
                <time datetime={toISODateTime(postDate)}>
                  {formatJPDate(postDate)}
                </time>

                <h2>
                  <a href={postUrl}>{post.data.title}</a>
                </h2>

                <div class="taxonomy">
                  <Taxonomy
                    category={post.data.category}
                    tags={post.data.tags}
                  />
                </div>

                {post.data.description && (
                  <p>
                    {truncateText(
                      post.data.description,
                      DESCRIPTION_MAX_LENGTH
                    )}
                  </p>
                )}
              </div>
            </article>
          </li>
        );
      })}
    </ul>
  ) : (
    <p>記事がありません。</p>
  )
}

<style lang="scss">
  // spacing
  @property --stack-gap {
    syntax: '<length>';
    inherits: false;
    initial-value: 24px;
  }

  .stack {
    > * + * {
      margin-top: var(--stack-gap, 1.5rem);
    }

    & time + *,
    & a + * {
      --stack-gap: 0;
    }

    & h2 + *,
    & .taxonomy + * {
      --stack-gap: 0.75rem;
    }
  }
</style>

<style lang="scss">
  // design
  @use '../styles/settings/variables' as *;

  ul {
    padding: 0;
    margin: 0;
    list-style: none;
  }

  ul li article {
    display: flex;
    gap: 1.5rem;
    padding: 1rem;
    border: 1px solid #777;
    border-radius: 12px;
    transition:
      box-shadow 0.2s ease,
      transform 0.2s ease;

    &:hover {
      background: #fff;
      box-shadow:
        0 8px 24px rgb(0 0 0 / 8%),
        0 0 0 1px rgb(0 0 0 / 15%);
      transform: translateY(-2px);
    }

    &:hover .thumbnail img {
      transform: scale(1.2);
    }
  }

  .thumbnail {
    flex-shrink: 0;
    align-self: center;
    width: 10rem;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border: 1px solid #777;
    border-radius: 12px;

    &:hover {
      outline: 2px solid rgb(0 0 238 / 80%);
    }
  }

  .thumbnail img {
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .meta-data {
    flex: 1;
    min-width: 0;
  }

  .meta-data time {
    font-size: 80%;
    color: #777;
    letter-spacing: 0.02em;
  }

  .meta-data h2 {
    font-size: 120%;
    line-height: 1.4;
  }

  .meta-data h2 a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;

    &:hover {
      color: $color-link;
    }
  }

  .meta-data p {
    display: -webkit-box;
    overflow: hidden;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    font-size: 90%;
    color: #777;
  }
</style>
