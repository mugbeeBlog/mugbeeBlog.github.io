---
import { getCollection, render } from 'astro:content';

type Platform = 'youtube' | 'info';
type PlatformColor = 'red' | 'gray';

interface PlatformConfig {
  label: string;
  color: PlatformColor;
}

const PLATFORM_CONFIG: Record<Platform, PlatformConfig> = {
  youtube: { label: 'YouTube', color: 'red' },
  info: { label: 'お知らせ', color: 'gray' },
} as const;

const MAX_MESSAGES = 3;

const calculateDaysDiff = (targetDate: Date, baseDate: Date): number => {
  const target = new Date(targetDate);
  const base = new Date(baseDate);

  target.setHours(0, 0, 0, 0);
  base.setHours(0, 0, 0, 0);

  return (base.getTime() - target.getTime()) / (1000 * 60 * 60 * 24);
};

const formatRelativeDate = (date: Date): string => {
  const diffDays = calculateDaysDiff(date, new Date());

  if (diffDays === 0) return '今日';
  if (diffDays === 1) return '昨日';
  if (diffDays < 0) return '未来';
  return `${Math.floor(diffDays)}日前`;
};

const sortByDateDesc = <T extends { data: { date: Date } }>(
  items: T[]
): T[] => {
  return [...items].sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
  );
};

const messages = await getCollection('messages');
const recentMessages = sortByDateDesc(messages).slice(0, MAX_MESSAGES);

const renderedMessages = await Promise.all(
  recentMessages.map(async (msg) => {
    const { Content } = await render(msg);
    return { data: msg.data, Content };
  })
);
---

{
  renderedMessages.length > 0 && (
    <ul>
      {renderedMessages.map(({ data, Content }) => {
        const config = PLATFORM_CONFIG[data.platform];

        return (
          <li class={`item item--${config.color}`}>
            <span class={`badge badge--${config.color}`}>{config.label}</span>

            <time
              datetime={data.date.toISOString()}
              title={data.date.toISOString()}
            >
              {formatRelativeDate(data.date)}
            </time>

            {data.url ? (
              <a href={data.url}>
                <Content />
              </a>
            ) : (
              <Content />
            )}
          </li>
        );
      })}
    </ul>
  )
}
