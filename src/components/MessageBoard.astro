---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

type Platform = 'youtube' | 'info';

interface PlatformConfig {
  label: string;
  color: string;
}

const PLATFORM_CONFIG: Record<Platform, PlatformConfig> = {
  youtube: { label: 'YouTube', color: 'red' },
  info: { label: 'お知らせ', color: 'gray' },
} as const;

const MAX_MESSAGES = 3;

const getRelativeDate = (date: Date): string => {
  const now = new Date();
  const target = new Date(date);

  now.setHours(0, 0, 0, 0);
  target.setHours(0, 0, 0, 0);

  const diffDays = Math.floor(
    (now.getTime() - target.getTime()) / (1000 * 60 * 60 * 24)
  );

  if (diffDays === 0) return '今日';
  if (diffDays === 1) return '昨日';
  if (diffDays < 0) return '未来';
  return `${diffDays}日前`;
};

const sortByDate = (
  messages: CollectionEntry<'messages'>[]
): CollectionEntry<'messages'>[] => {
  return [...messages].sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime()
  );
};

const messages = await getCollection('messages');
const recentMessages = sortByDate(messages).slice(0, MAX_MESSAGES);

const renderedMessages = await Promise.all(
  recentMessages.map(async (message) => {
    const { Content } = await render(message);
    const config = PLATFORM_CONFIG[message.data.platform];

    return {
      platform: message.data.platform,
      date: message.data.date,
      url: message.data.url,
      label: config.label,
      Content,
    };
  })
);
---

{
  renderedMessages.length > 0 && (
    <ul class="stack">
      {renderedMessages.map(({ platform, date, url, label, Content }) => (
        <li data-platform={platform}>
          <span>{label}</span>

          <time
            datetime={date.toISOString()}
            title={date.toLocaleDateString('ja-JP', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          >
            {getRelativeDate(date)}
          </time>

          <div class="content">
            {url ? (
              <a href={url}>
                <Content />
              </a>
            ) : (
              <Content />
            )}
          </div>
        </li>
      ))}
    </ul>
  )
}

<style lang="scss">
  // Stack component
  @property --stack-gap {
    syntax: '<length>';
    inherits: false;
    initial-value: 24px;
  }

  .stack {
    > * + * {
      margin-top: var(--stack-gap, 1.5rem);
    }

    & li + * {
      margin-top: 0.5rem;
    }
  }
</style>

<style lang="scss">
  ul {
    margin: 0;
  }

  li {
    display: grid;
    grid-template-columns: 4rem auto 1fr;
    gap: 0.5rem;
    align-items: center;
    font-size: 90%;
    transition: background-color 0.2s ease;

    &:hover {
      background-color: #f5f5f5;
    }
  }

  li span {
    padding: 0.3rem;
    font-size: 75%;
    font-weight: 700;
    color: #fff;
    text-align: center;
    white-space: nowrap;
    border-radius: 3px;
  }

  li[data-platform='youtube'] span {
    background-color: #f00;
  }

  li[data-platform='info'] span {
    background-color: #666;
  }

  time {
    display: inline-block;
    min-width: 3rem;
    padding: 0.2rem;
    font-size: 80%;
    color: #777;
    text-align: end;
    white-space: nowrap;
    border: 1px solid #777;
    border-radius: 3px;
  }

  .content {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>
