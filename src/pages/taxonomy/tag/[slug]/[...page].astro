---
import { getCollection, type CollectionEntry } from 'astro:content';
import type { GetStaticPathsOptions } from 'astro';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../../components/ArticleCard.astro';
import Pagination from '../../../../components/Pagination.astro';
import { pagination } from '../../../../data/constants';

export const getStaticPaths = async ({ paginate }: GetStaticPathsOptions) => {
  const blogs = await getCollection('blogs');

  const tagMap = new Map<
    string,
    { name: string; slug: string; posts: CollectionEntry<'blogs'>[] }
  >();

  blogs.forEach((post) => {
    const tags = post.data.tags ?? [];
    tags.forEach((tag) => {
      const slug = tag.slug ?? tag.id;

      let entry = tagMap.get(slug);

      if (!entry) {
        entry = { name: tag.name, slug, posts: [] };
        tagMap.set(slug, entry);
      }

      entry.posts.push(post);
    });
  });

  const paths = [];

  for (const { name, slug, posts } of tagMap.values()) {
    const typedPosts = posts as CollectionEntry<'blogs'>[];

    const paginated = paginate(typedPosts, {
      pageSize: pagination.pageSize,
      params: { slug },
      props: { name },
    });

    paths.push(...paginated);
  }

  return paths;
};

const { page, name } = Astro.props;
---

<BaseLayout
  title={`タグ: ${name} - ${page.currentPage}ページ目`}
  noindex={true}
>
  <div class="stack">
    <header>
      <h1>
        タグ: {name}
        <span>（{page.total}件 - {page.currentPage}ページ目）</span>
      </h1>
    </header>

    <div class="article-card">
      <ArticleCard blogs={page.data} />
    </div>

    <div class="pagination">
      <Pagination
        currentPage={page.currentPage}
        lastPage={page.lastPage}
        basePath={`/taxonomy/tag/${Astro.params.slug}`}
      />
    </div>
  </div>
</BaseLayout>
