---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blogs');

type TaxonomyCount = {
  name: string;
  slug: string;
  count: number;
};

const processTaxonomy = (
  items: { id: string; name: string; slug?: string }[] | undefined,
  map: Map<string, TaxonomyCount>
) => {
  if (!items) return;

  items.forEach((item) => {
    const slug = item.slug ?? item.id;
    const entry = map.get(slug);

    if (entry) {
      entry.count++;
    } else {
      map.set(slug, { name: item.name, slug, count: 1 });
    }
  });
};

const categoryMap = new Map<string, TaxonomyCount>();
const tagMap = new Map<string, TaxonomyCount>();

posts.forEach((post) => {
  processTaxonomy(post.data.category, categoryMap);
  processTaxonomy(post.data.tags, tagMap);
});

const categories = Array.from(categoryMap.values()).sort(
  (a, b) => b.count - a.count || a.name.localeCompare(b.name)
);
const tags = Array.from(tagMap.values()).sort(
  (a, b) => b.count - a.count || a.name.localeCompare(b.name)
);
---

<BaseLayout title="カテゴリ & タグ 一覧">
  <h1>カテゴリ一覧</h1>
  {
    categories.length > 0 ? (
      <ul>
        {categories.map((cat) => (
          <li>
            <a href={`/taxonomy/category/${cat.slug}/`}>
              {cat.name} ({cat.count})
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p>カテゴリがありません。</p>
    )
  }

  <h1>タグ一覧</h1>
  {
    tags.length > 0 ? (
      <ul>
        {tags.map((tag) => (
          <li>
            <a href={`/taxonomy/tag/${tag.slug}/`}>
              #{tag.name} ({tag.count})
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p>タグがありません。</p>
    )
  }
</BaseLayout>
