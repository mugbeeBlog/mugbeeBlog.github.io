{
  // ESLint Flat Config
  "eslint.useFlatConfig": true,
  "eslint.workingDirectories": [{ "mode": "auto" }],
  "eslint.validate": ["javascript", "typescript", "astro"],

  // Fix on Save
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.fixAll.eslint": "explicit",
    "source.fixAll.stylelint": "explicit"
  },

  // Astro
  "files.associations": {
    "*.astro": "astro"
  },

  // Prettier
  "editor.defaultFormatter": "esbenp.prettier-vscode",

  // Stylelint
  "stylelint.validate": ["css", "scss", "html", "astro"],
  "stylelint.configFile": "stylelint.config.mjs",

  // Editor
  "editor.insertSpaces": true,
  "diffEditor.codeLens": true,
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "on",
    "strings": "on"
  },

  // Emmet
  "emmet.includeLanguages": {
    "astro": "html"
  },
  "emmet.variables": {
    "lang": "ja"
  },

  // cSpell
  "cSpell.words": ["microcms", "Mugbee", "mugbeeblog", "noto", "partytown"],
  "cSpell.ignoreRegExpList": ["[０-９Ａ-Ｚａ-ｚぁ-んァ-ヶ亜-熙纊-黑]+"], // 日本語を無視
  "cSpell.ignorePaths": ["docs/_generated/**"]
}
